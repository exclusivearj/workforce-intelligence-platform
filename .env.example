# ── Postgres ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=workforce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Per-role credentials (created by 1-ingestion bootstrap_roles())
INGESTION_WRITER_PASSWORD=changeme_writer
DBT_TRANSFORMER_PASSWORD=changeme_dbt
ANALYST_READER_PASSWORD=changeme_reader
HR_PARTNER_PASSWORD=changeme_hr_partner
LEGAL_PASSWORD=changeme_legal

# Full SQLAlchemy/psql URL for the workforce DB (used by governance apply-ddl)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/workforce

# ── Trino ─────────────────────────────────────────────────────
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_USER=trino

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW_ADMIN_PASSWORD=admin

# ── Airtable (free account — real credentials) ────────────────
AIRTABLE_API_KEY=your_airtable_pat_here
AIRTABLE_BASE_ID=your_base_id_here

# ── OpenAI / embeddings ───────────────────────────────────────
# 'local' (sentence-transformers, zero cost, default) or 'openai'
EMBEDDING_BACKEND=local
# Required only when EMBEDDING_BACKEND=openai
OPENAI_API_KEY=

# ── Workday / Greenhouse mock connectors ──────────────────────
WORKDAY_BASE_URL=http://localhost:5001
WORKDAY_API_TOKEN=mock-token
GREENHOUSE_BASE_URL=http://localhost:5002
GREENHOUSE_API_KEY=mock-key

# ── Slack alerts (optional) ───────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Streamlit Cloud (set during deploy) ───────────────────────
STREAMLIT_TRINO_HOST=localhost
STREAMLIT_TRINO_PORT=8080
